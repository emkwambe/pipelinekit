{
  "name": "stripe-to-snowflake",
  "version": "1.0.0",
  "description": "Stripe payments to Snowflake trusted analytics pipeline",
  "source": {
    "type": "stripe",
    "dlt_source": "stripe"
  },
  "destination": {
    "type": "snowflake",
    "dlt_destination": "snowflake"
  },
  "contracts": [
    "contracts/charges.yaml",
    "contracts/customers.yaml"
  ],
  "tags": [
    "stripe",
    "snowflake",
    "payments-analytics"
  ],
  "kpis": [
    "Daily Revenue",
    "Charge Volume",
    "Refund Rate",
    "Average Charge Value",
    "New Customers",
    "Customer Lifetime Value"
  ],
  "deploy_time_minutes": 60,
  "time_to_trusted_data_hours": 4,
  "can_auto_apply": false
}
