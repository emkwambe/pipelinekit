%% PipelineKit — CLI Command Map (Engineering / Maintenance)
%% Audience: engineers, maintainers, on-call.
%% Commands and flags verified against src/pipelinekit/cli/main.py and each command module.
%% Dotted edges show state.db tables read/written and external systems called.
flowchart LR
    root(["pipelinekit"])

    %% --- Core ---
    root --> init["init"]
    root --> validate["validate [--contracts]"]
    root --> run["run [--dry-run]"]
    root --> status["status"]

    %% --- blueprint group ---
    root --> bp["blueprint"]
    bp --> bp_list["list"]
    bp --> bp_val["validate [name]"]
    bp --> bp_info["info &lt;name&gt;"]
    bp --> bp_search["search &lt;query&gt; [--verified]"]
    bp --> bp_install["install &lt;name&gt; [--version] [--force]"]

    %% --- generate group ---
    root --> gen["generate"]
    gen --> gen_bp["blueprint -s -d -t [--plan|--interactive] [-p] [-n]"]
    gen --> gen_show["show &lt;plan-id&gt;"]

    %% --- apply group ---
    root --> apply["apply"]
    apply --> apply_plan["plan &lt;plan-id&gt; [--interactive]"]

    %% --- diagnose ---
    root --> diag["diagnose [run-id] [--provider] [--approve]"]

    %% --- architect group ---
    root --> arch["architect"]
    arch --> arch_an["analyze [question] [--type] [--provider] [--approve]"]
    arch --> arch_adr["check-adrs &lt;change&gt; [--provider]"]
    arch --> arch_cmp["compare &lt;tool-a&gt; &lt;tool-b&gt; [--provider]"]

    %% --- health group ---
    root --> health["health [--strict]"]
    health --> h_deps["deps"]
    health --> h_sec["security"]
    health --> h_bp["blueprints"]
    health --> h_specs["specs [--fix]"]
    health --> h_tests["tests"]

    %% --- migrate group ---
    root --> mig["migrate"]
    mig --> mig_an["analyze &lt;config&gt; [--provider] [--apply] [--write-draft]"]

    %% --- state.db tables ---
    subgraph SDB["state.db (8 tables)"]
        t_runs["pipeline_runs"]
        t_contract["contract_results"]
        t_diag["diagnostic_results"]
        t_arch["architecture_results"]
        t_health["health_runs"]
        t_prop["blueprint_proposals"]
        t_inst["installed_blueprints"]
    end

    %% --- external systems ---
    subgraph EXT["External systems"]
        ext_data["dlt / dbt / Soda"]
        ext_llm["AI provider API"]
        ext_reg["Remote registry"]
        ext_fs["filesystem (pipelinekit.yaml / blueprints/)"]
    end

    %% state + external interactions (verified)
    init -.->|writes| ext_fs
    validate -.->|reads| ext_fs
    run -.->|"writes pending+final"| t_runs
    run -.->|executes| ext_data
    status -.->|reads| t_runs
    bp_install -.->|writes| t_inst
    bp_search -.->|calls| ext_reg
    bp_install -.->|calls| ext_reg
    gen_bp -.->|writes| t_prop
    gen_bp -.->|calls| ext_llm
    gen_show -.->|reads| t_prop
    apply_plan -.->|"reads/updates"| t_prop
    apply_plan -.->|writes| ext_fs
    diag -.->|"reads runs / writes"| t_diag
    diag -.->|calls| ext_llm
    arch_an -.->|writes| t_arch
    arch_an -.->|calls| ext_llm
    health -.->|writes| t_health
    mig_an -.->|calls| ext_llm
    mig_an -.->|"writes pipelinekit.proposed.yaml"| ext_fs
