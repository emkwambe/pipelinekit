%% PipelineKit — Error Code Taxonomy (Maintenance / On-Call)
%% Audience: on-call engineers, support.
%% Classes verified against src/pipelinekit/core/errors.py.
%% Code RANGES verified against docs/reference/Error-Codes.md.
%% PK-ADAPTER-* and PK-NOTIFY-* have no dedicated subclass yet — carried by base.
flowchart TB
    base["PipelineKitError<br/>(code, message, context)"]

    base --> cfg["ConfigurationError — PK-CONFIG-001..006<br/>cmd: init, validate<br/>fix: correct pipelinekit.yaml / set ${VAR}"]
    base --> state["StateError — PK-STATE-001..003<br/>cmd: any (state.db)<br/>fix: check .pipelinekit/ permissions"]
    base --> rt["RuntimeError — PK-RUNTIME-001..003<br/>cmd: run<br/>fix: read the failing step detail"]
    base --> contract["ContractError — PK-CONTRACT-001..008<br/>cmd: validate --contracts, run<br/>fix: fix source data or contract"]
    base --> bp["BlueprintError — PK-BLUEPRINT-001..004<br/>cmd: blueprint validate/info<br/>fix: fix manifest / directory"]
    base --> diagc["DiagnosticsError — PK-DIAG-001..003<br/>cmd: diagnose<br/>fix: check run id / evidence in state"]
    base --> llm["LLMError — PK-AI-001..003<br/>cmd: diagnose, architect, generate, migrate<br/>fix: set provider API key / retry"]
    base --> arch["ArchitectureError — PK-ARCH-001..004<br/>cmd: architect<br/>fix: run more pipelines (history)"]
    base --> health["HealthError — PK-HEALTH-001..004<br/>cmd: health<br/>fix: install poetry / pip-audit"]
    base --> prop["ProposalError — PK-GEN-001..007<br/>cmd: generate, apply<br/>fix: follow the review flow"]
    base --> reg["RegistryError — PK-REGISTRY-001..005<br/>cmd: blueprint search/install<br/>fix: connectivity / --force"]
    base --> mig["MigrationError — PK-MIGRATE-001..005<br/>cmd: migrate analyze<br/>fix: check path/format / --write-draft"]

    subgraph NOCLASS["Code families carried by base PipelineKitError (no dedicated subclass)"]
        direction LR
        adapter["PK-ADAPTER-001..003<br/>cmd: run<br/>fix: check source/dest reachability & creds"]
        notify["PK-NOTIFY-001..004<br/>cmd: run (notifications)<br/>fix: set RESEND_API_KEY / fix recipient"]
    end
    base -.-> NOCLASS

    classDef errnode fill:#3a1f1f,color:#fdd,stroke:#c66;
    class cfg,state,rt,contract,bp,diagc,llm,arch,health,prop,reg,mig,adapter,notify errnode;
