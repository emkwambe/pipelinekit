        a6["alerts/config.yaml"]
        a7["docs/README.md"]
        a8["docs/runbook.md or RUNBOOK.md"]
    end

    subgraph VERIFY["Verification lifecycle"]
        direction LR
        v0["proposed"] --> v1["approved"] --> v2["written"] --> v3["validated"] --> v4["locally verified"] --> v5["production verified"]
