{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PipelineKit Blueprint Proposal",
  "type": "object",
  "required": ["plan_id", "blueprint_name", "source_type", "destination_type", "tables", "assets", "confidence"],
  "properties": {
    "plan_id": {"type": "string"},
    "blueprint_name": {"type": "string"},
    "source_type": {"type": "string"},
    "destination_type": {"type": "string"},
    "tables": {"type": "array", "items": {"type": "string"}},
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["asset_type", "filename", "content", "state"],
        "properties": {
          "asset_type": {"type": "string"},
          "filename": {"type": "string"},
          "content": {"type": "string"},
          "state": {
            "type": "string",
            "enum": ["proposed", "approved", "rejected", "edited", "written", "validated"]
          }
        }
      }
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "assumptions": {"type": "array"},
    "unsupported_areas": {"type": "array"},
    "requires_human_decisions": {"type": "array"},
    "provider": {"type": "string"},
    "generated_at": {"type": "string"},
    "can_auto_apply": {"type": "boolean", "default": false},
    "applied": {"type": "boolean", "default": false}
  }
}
